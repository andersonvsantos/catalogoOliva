{
  "version": 2,
  "builds": [
    {
      "src": "assets/js/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "admin.html",
      "use": "@vercel/static"
    },
    {
      "src": "assets/css/*.css",
      "use": "@vercel/static"
    },
    {
      "src": "assets/js/admin.js",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "assets/js/server.js"
    }
  ]
}