{
  "version": 2,
  "builds": [
    { "src": "assets/js/server.js", "use": "@vercel/node" },
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "assets/css/*.css", "use": "@vercel/static" },
    { "src": "assets/js/*.js", "use": "@vercel/static" }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "assets/js/server.js" }
  ]
}